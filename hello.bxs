// Compress
new ortus.boxlang.runtime.util.ZipFile()
    .source( "/path/to/folder" )
    .to( "/path/to/archive.zip" )
    .compress();

// Extract
new ortus.boxlang.runtime.util.ZipFile()
    .source( "/path/to/archive.zip" )
    .to( "/path/to/output/" )
    .extract();

// List contents
entries = new ortus.boxlang.runtime.util.ZipFile()
    .source( "/path/to/archive.zip" )
    .list();